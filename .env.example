# Local development environment variables for APL Migration Platform
# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# ============================================================

# ============================================================
# AI PROVIDER SELECTION (Multi-Provider Architecture)
# ============================================================
# How to use:
#   PRIVATE MODE (local, no API key needed):
#     AI_MODE=private
#     AI_PROVIDER=ollama
#     (Requires Ollama running locally with qwen2.5-coder:3b)
#
#   PUBLIC MODE - Gemini (WORKING - has API key):
#     AI_MODE=public
#     AI_PROVIDER=gemini
#     GEMINI_API_KEY=<your-gemini-api-key>
#
#   PUBLIC MODE - Claude (SCAFFOLDED - add API key when ready):
#     AI_MODE=public
#     AI_PROVIDER=claude
#     CLAUDE_API_KEY=<your-claude-api-key>
#
#   PUBLIC MODE - OpenAI (SCAFFOLDED - add API key when ready):
#     AI_MODE=public
#     AI_PROVIDER=openai
#     OPENAI_API_KEY=<your-openai-api-key>

AI_MODE="private"
AI_PROVIDER="ollama"

# ============================================================
# PRIVATE MODE - Ollama (Local Inference)
# ============================================================
# Instructions:
#   1. Install Ollama: https://ollama.ai
#   2. Pull model: ollama pull qwen2.5-coder:3b
#   3. Start server: ollama serve
#   4. Set OLLAMA_URL to where Ollama is running
#   5. Set MODEL_NAME to the model you want to use

OLLAMA_URL="http://localhost:11434"
MODEL_NAME="qwen2.5-coder:3b"

# ============================================================
# PUBLIC MODE - Gemini API
# ============================================================
# Status: ✅ WORKING (if API key configured)
# Instructions:
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Create a new API key
#   3. Paste it below
# Note: This key is already available, making public mode work immediately

GEMINI_API_KEY="AIzaSyCd6VNDGlmR0pYNYnlIgW3PvtDV6GmoTuA"
GEMINI_MODEL="gemini-2.5-pro"

# ============================================================
# PUBLIC MODE - Claude API
# ============================================================
# Status: 🔶 SCAFFOLDED (framework ready, just add API key)
# Instructions:
#   1. Go to https://console.anthropic.com/
#   2. Create API key
#   3. Paste it below
# When API key is set, Claude will be available as a provider

CLAUDE_API_KEY=""
CLAUDE_MODEL="claude-sonnet-4"

# ============================================================
# PUBLIC MODE - OpenAI API
# ============================================================
# Status: 🔶 SCAFFOLDED (framework ready, just add API key)
# Instructions:
#   1. Go to https://platform.openai.com/api-keys
#   2. Create API key
#   3. Paste it below
# When API key is set, OpenAI will be available as a provider

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4-turbo"

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/apl_migration"

# ============================================================
# RUNTIME SETTINGS
# ============================================================
CORS_ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:5173"]'
VITE_BACKEND_URL="http://localhost:3000"
ENVIRONMENT="development"
TIMEOUT_SECONDS=60
RETRY_ATTEMPTS=2
LOG_LEVEL="INFO"

# ============================================================
# APL EXECUTION (Dyalog APL)
# ============================================================
# On Windows, specify path to dyalog.exe
# On Linux/Mac, just use "dyalog"
DYALOG_EXECUTABLE="dyalog"
PYTHON_EXECUTABLE="python"

# ============================================================
# OUTPUT DIRECTORIES
# ============================================================
OUTPUT_DIR="outputs"
REPORTS_DIR="outputs/reports"

